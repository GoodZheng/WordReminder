<Window x:Class="WordReminder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="420"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- 窗口设置页 -->
            <TabItem Header="窗口">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">

                        <TextBlock Text="窗口行为" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <CheckBox x:Name="AlwaysOnTopCheckBox" Content="窗口置顶" IsChecked="True" Margin="0,5"/>
                        <CheckBox x:Name="AutoStartCheckBox" Content="开机自启" IsChecked="False" Margin="0,5"/>

                        <Separator Margin="0,15"/>

                        <TextBlock Text="显示效果" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- 切换间隔 -->
                        <StackPanel Margin="0,5">
                            <Grid>
                                <TextBlock Text="切换间隔" VerticalAlignment="Center"/>
                                <TextBlock x:Name="IntervalValue" Text="10秒" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="IntervalSlider" Minimum="1" Maximum="300" Value="10" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,5"/>
                        </StackPanel>

                        <!-- 透明度 -->
                        <StackPanel Margin="0,5">
                            <Grid>
                                <TextBlock Text="窗口透明度" VerticalAlignment="Center"/>
                                <TextBlock x:Name="OpacityValue" Text="100%" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0" Value="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,5"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 内容设置页 -->
            <TabItem Header="内容">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">

                        <TextBlock Text="显示内容" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <CheckBox x:Name="ShowPhoneticCheckBox" Content="显示音标" IsChecked="True" Margin="0,8"/>
                        <TextBlock Text="在单词右侧显示音标" FontSize="12" Foreground="Gray" Margin="20,0,0,5"/>

                        <CheckBox x:Name="ShowDefinitionCheckBox" Content="显示释义" IsChecked="True" Margin="0,8"/>
                        <TextBlock Text="显示词性和中文释义" FontSize="12" Foreground="Gray" Margin="20,0,0,5"/>

                        <CheckBox x:Name="ShowExampleCheckBox" Content="显示例句" IsChecked="True" Margin="0,8"/>
                        <TextBlock Text="显示英文例句" FontSize="12" Foreground="Gray" Margin="20,0,0,5"/>

                        <Separator Margin="0,20"/>

                        <!-- 样式设置 -->
                        <TextBlock Text="字体样式" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- 单词样式 -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="单词" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="WordFontSizeSlider" Minimum="12" Maximum="72" Value="32" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="WordFontSizeValue" Grid.Column="1" Text="32" Width="25" TextAlignment="Right"/>
                            </Grid>

                            <Button x:Name="WordColorButton" Grid.Column="2" Width="40" Height="22" Margin="5,0,0,0" Click="ColorButton_Click" Tag="Word">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- 音标样式 -->
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="音标" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="PhoneticFontSizeSlider" Minimum="8" Maximum="36" Value="16" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="PhoneticFontSizeValue" Grid.Column="1" Text="16" Width="25" TextAlignment="Right"/>
                            </Grid>

                            <Button x:Name="PhoneticColorButton" Grid.Column="2" Width="40" Height="22" Margin="5,0,0,0" Click="ColorButton_Click" Tag="Phonetic">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- 释义样式 -->
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="释义" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="DefinitionFontSizeSlider" Minimum="10" Maximum="36" Value="18" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="DefinitionFontSizeValue" Grid.Column="1" Text="18" Width="25" TextAlignment="Right"/>
                            </Grid>

                            <Button x:Name="DefinitionColorButton" Grid.Column="2" Width="40" Height="22" Margin="5,0,0,0" Click="ColorButton_Click" Tag="Definition">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- 例句样式 -->
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="例句" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="ExampleFontSizeSlider" Minimum="8" Maximum="24" Value="14" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="ExampleFontSizeValue" Grid.Column="1" Text="14" Width="25" TextAlignment="Right"/>
                            </Grid>

                            <Button x:Name="ExampleColorButton" Grid.Column="2" Width="40" Height="22" Margin="5,0,0,0" Click="ColorButton_Click" Tag="Example">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <TextBlock Text="点击右侧颜色块打开颜色选择器" FontSize="11" Foreground="Gray" Margin="0,5,0,0" HorizontalAlignment="Center"/>

                        <Separator Margin="0,20"/>

                        <!-- 单词管理 -->
                        <TextBlock Text="单词数据" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock x:Name="WordCountText" Text="当前单词数: 0" Margin="0,5" FontSize="14"/>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,5">
                            重新加载会从必应词典获取最新的单词数据，包括音标、释义和例句。
                        </TextBlock>

                        <Button x:Name="ReloadWordsButton" Content="重新加载单词数据" Click="ReloadWords_Click" Margin="0,15" Height="35"/>

                        <Separator Margin="0,20"/>

                        <TextBlock Text="关于" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray">
                            单词来源：内置20个四级核心词汇，支持从必应词典获取例句。
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 关于页 -->
            <TabItem Header="关于">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- 应用图标和名称 -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock Text="📚 WordReminder" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="桌面单词记忆软件" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- 版本信息 -->
                        <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel>
                                <Grid Margin="0,5">
                                    <TextBlock Text="当前版本" FontWeight="Bold"/>
                                    <TextBlock x:Name="CurrentVersionText" Text="1.0.0" HorizontalAlignment="Right" Foreground="Gray"/>
                                </Grid>
                                <Grid Margin="0,5">
                                    <TextBlock Text="最新版本" FontWeight="Bold"/>
                                    <TextBlock x:Name="LatestVersionText" Text="检查中..." HorizontalAlignment="Right" Foreground="Gray"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 更新操作 -->
                        <Button x:Name="CheckUpdateButton" Content="检查更新" Click="CheckUpdate_Click" Margin="0,0,0,10" Height="40" FontSize="14"/>
                        <Button x:Name="DownloadUpdateButton" Content="下载更新" Click="DownloadUpdate_Click" Margin="0,0,0,10" Height="40" FontSize="14" IsEnabled="False" Visibility="Collapsed"/>

                        <!-- 下载进度 -->
                        <Border x:Name="DownloadProgressPanel" Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,15" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="DownloadStatusText" Text="正在下载..." Margin="0,0,0,10"/>
                                <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </Border>

                        <!-- 自动更新开关 -->
                        <CheckBox x:Name="AutoUpdateCheckBox" Content="自动检查更新（启动时）" IsChecked="True" Margin="0,10"/>

                        <Separator Margin="0,20"/>

                        <!-- 开发者信息 -->
                        <TextBlock Text="开发者信息" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            <Run Text="开发者：" FontWeight="Bold"/>
                            <Run Text="WordReminder Team"/>
                        </TextBlock>

                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            <Run Text="GitHub：" FontWeight="Bold"/>
                            <Run Text="github.com/GoodZheng/WordReminder" Foreground="Blue" Cursor="Hand" MouseDown="OpenGitHubLink_MouseDown"/>
                        </TextBlock>

                        <Separator Margin="0,20"/>

                        <!-- 版权信息 -->
                        <TextBlock Text="版权" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,5">
                            © 2025 WordReminder. All rights reserved.
                        </TextBlock>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,5">
                            本软件免费开源，仅供学习使用。
                        </TextBlock>

                        <Separator Margin="0,20"/>

                        <!-- 功能说明 -->
                        <TextBlock Text="功能说明" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 透明窗口展示单词
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 内置20个四级核心词汇
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 支持从必应词典获取单词详情
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 可自定义字体、颜色、透明度
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 支持开机自启
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- 保存按钮 -->
        <Button Grid.Row="1" x:Name="SaveButton" Content="保存设置" Click="Save_Click" Margin="0,15,0,0" Height="40" FontSize="14"/>

    </Grid>

</Window>
