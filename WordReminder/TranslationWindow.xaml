<Window x:Class="WordReminder.TranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="万能翻译"
        Width="600"
        Height="500"
        MinWidth="500"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 输入区域 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="请输入要翻译的文本（支持中英文互翻）" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
            <Grid>
                <TextBox x:Name="InputTextBox"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="14"
                         Padding="8"
                         KeyDown="InputTextBox_KeyDown"/>
            </Grid>
        </StackPanel>

        <!-- 翻译按钮 -->
        <Button x:Name="TranslateButton"
                Grid.Row="1"
                Content="翻译"
                Width="100"
                Height="32"
                HorizontalAlignment="Left"
                Click="TranslateButton_Click"
                Margin="0,0,0,10"/>

        <!-- 结果区域 -->
        <Border Grid.Row="2"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ResultPanel">
                    <!-- 加载提示 -->
                    <TextBlock x:Name="LoadingText"
                               Text="请输入文本后点击翻译"
                               Foreground="#999999"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Visibility="Visible"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪" FontSize="11" Foreground="#888888"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
