<Window x:Class="WordReminder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WordReminder"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False"
            NonClientFrameEdges="None"
            GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Border x:Name="MainBorder"
            Background="Transparent"
            CornerRadius="8"
            Padding="20">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 第一行：单词 + 音标 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock x:Name="WordText"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Text="Loading..."/>

                <TextBlock x:Name="PhoneticText"
                           FontSize="16"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- 第二行：词性和释义 -->
            <TextBlock x:Name="DefinitionText"
                       Grid.Row="1"
                       FontSize="18"
                       Foreground="#EEEEEE"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>

            <!-- 第三行：例句 -->
            <TextBlock x:Name="ExampleText"
                       Grid.Row="2"
                       FontSize="14"
                       Foreground="#AAAAAA"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       Visibility="Collapsed"/>

        </Grid>
    </Border>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="播放/暂停" Click="PlayPause_Click"/>
            <MenuItem Header="上一个" Click="Previous_Click"/>
            <MenuItem Header="下一个" Click="Next_Click"/>
            <Separator/>
            <MenuItem Header="添加单词..." Click="AddWord_Click"/>
            <MenuItem Header="所有单词..." Click="AllWords_Click"/>
            <Separator/>
            <MenuItem Header="翻译" Click="Translate_Click"/>
            <Separator/>
            <MenuItem Header="设置..." Click="Settings_Click"/>
            <Separator/>
            <MenuItem Header="退出" Click="Exit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

</Window>
