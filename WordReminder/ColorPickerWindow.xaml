<Window x:Class="WordReminder.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择颜色"
        Width="280"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Text="选择颜色" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- 颜色网格 -->
        <UniformGrid Grid.Row="1" Columns="6" Margin="0,5">
            <!-- 白色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#FFFFFF" Click="ColorButton_Click" Tag="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1"/>
            <Button Width="30" Height="30" Margin="2" Background="#DDDDDD" Click="ColorButton_Click" Tag="#DDDDDD"/>
            <Button Width="30" Height="30" Margin="2" Background="#CCCCCC" Click="ColorButton_Click" Tag="#CCCCCC"/>
            <Button Width="30" Height="30" Margin="2" Background="#AAAAAA" Click="ColorButton_Click" Tag="#AAAAAA"/>
            <Button Width="30" Height="30" Margin="2" Background="#888888" Click="ColorButton_Click" Tag="#888888"/>
            <Button Width="30" Height="30" Margin="2" Background="#666666" Click="ColorButton_Click" Tag="#666666"/>

            <!-- 红色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#FF6B6B" Click="ColorButton_Click" Tag="#FF6B6B"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF4444" Click="ColorButton_Click" Tag="#FF4444"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF0000" Click="ColorButton_Click" Tag="#FF0000"/>
            <Button Width="30" Height="30" Margin="2" Background="#FFB6C1" Click="ColorButton_Click" Tag="#FFB6C1"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF69B4" Click="ColorButton_Click" Tag="#FF69B4"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF1493" Click="ColorButton_Click" Tag="#FF1493"/>

            <!-- 橙黄色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#FFA500" Click="ColorButton_Click" Tag="#FFA500"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF8C00" Click="ColorButton_Click" Tag="#FF8C00"/>
            <Button Width="30" Height="30" Margin="2" Background="#FFD700" Click="ColorButton_Click" Tag="#FFD700"/>
            <Button Width="30" Height="30" Margin="2" Background="#FFFF00" Click="ColorButton_Click" Tag="#FFFF00"/>
            <Button Width="30" Height="30" Margin="2" Background="#F0E68C" Click="ColorButton_Click" Tag="#F0E68C"/>
            <Button Width="30" Height="30" Margin="2" Background="#B8860B" Click="ColorButton_Click" Tag="#B8860B"/>

            <!-- 绿色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#90EE90" Click="ColorButton_Click" Tag="#90EE90"/>
            <Button Width="30" Height="30" Margin="2" Background="#00FF00" Click="ColorButton_Click" Tag="#00FF00"/>
            <Button Width="30" Height="30" Margin="2" Background="#32CD32" Click="ColorButton_Click" Tag="#32CD32"/>
            <Button Width="30" Height="30" Margin="2" Background="#228B22" Click="ColorButton_Click" Tag="#228B22"/>
            <Button Width="30" Height="30" Margin="2" Background="#008000" Click="ColorButton_Click" Tag="#008000"/>
            <Button Width="30" Height="30" Margin="2" Background="#006400" Click="ColorButton_Click" Tag="#006400"/>

            <!-- 青色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#00FFFF" Click="ColorButton_Click" Tag="#00FFFF"/>
            <Button Width="30" Height="30" Margin="2" Background="#00CED1" Click="ColorButton_Click" Tag="#00CED1"/>
            <Button Width="30" Height="30" Margin="2" Background="#20B2AA" Click="ColorButton_Click" Tag="#20B2AA"/>
            <Button Width="30" Height="30" Margin="2" Background="#008B8B" Click="ColorButton_Click" Tag="#008B8B"/>
            <Button Width="30" Height="30" Margin="2" Background="#5F9EA0" Click="ColorButton_Click" Tag="#5F9EA0"/>
            <Button Width="30" Height="30" Margin="2" Background="#4682B4" Click="ColorButton_Click" Tag="#4682B4"/>

            <!-- 蓝色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#87CEEB" Click="ColorButton_Click" Tag="#87CEEB"/>
            <Button Width="30" Height="30" Margin="2" Background="#1E90FF" Click="ColorButton_Click" Tag="#1E90FF"/>
            <Button Width="30" Height="30" Margin="2" Background="#0000FF" Click="ColorButton_Click" Tag="#0000FF"/>
            <Button Width="30" Height="30" Margin="2" Background="#4169E1" Click="ColorButton_Click" Tag="#4169E1"/>
            <Button Width="30" Height="30" Margin="2" Background="#00008B" Click="ColorButton_Click" Tag="#00008B"/>
            <Button Width="30" Height="30" Margin="2" Background="#191970" Click="ColorButton_Click" Tag="#191970"/>

            <!-- 紫色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#DDA0DD" Click="ColorButton_Click" Tag="#DDA0DD"/>
            <Button Width="30" Height="30" Margin="2" Background="#DA70D6" Click="ColorButton_Click" Tag="#DA70D6"/>
            <Button Width="30" Height="30" Margin="2" Background="#9370DB" Click="ColorButton_Click" Tag="#9370DB"/>
            <Button Width="30" Height="30" Margin="2" Background="#8A2BE2" Click="ColorButton_Click" Tag="#8A2BE2"/>
            <Button Width="30" Height="30" Margin="2" Background="#9400D3" Click="ColorButton_Click" Tag="#9400D3"/>
            <Button Width="30" Height="30" Margin="2" Background="#4B0082" Click="ColorButton_Click" Tag="#4B0082"/>
        </UniformGrid>

        <!-- 自定义颜色输入 -->
        <Grid Grid.Row="2" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="自定义:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="CustomColorTextBox" Grid.Column="1" VerticalAlignment="Center" Text="#FFFFFF"/>
            <Border Grid.Column="2" Width="30" Height="22" Margin="8,0,0,0" BorderBrush="#CCCCCC" BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush x:Name="PreviewBrush" Color="White"/>
                </Border.Background>
            </Border>
        </Grid>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="75" Height="28" Margin="5,0" Click="OK_Click" IsDefault="True"/>
            <Button Content="取消" Width="75" Height="28" Margin="5,0" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>

    </Grid>

</Window>
