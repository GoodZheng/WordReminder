<Window x:Class="WordReminder.Views.TranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WordReminder.Converters"
        Title="万能翻译"
        Width="600"
        Height="500"
        MinWidth="500"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 输入区域 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="请输入要翻译的文本（支持中英文互翻）" FontSize="12" Foreground="#666666" Margin="0,0,0,5"/>
            <TextBox Height="80"
                     Name="InputTextBox"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="14"
                     Padding="8"
                     PreviewKeyDown="InputTextBox_PreviewKeyDown"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- 翻译按钮 -->
        <Button Grid.Row="1"
                Content="翻译"
                Width="100"
                Height="32"
                HorizontalAlignment="Left"
                Command="{Binding TranslateCommand}"
                IsEnabled="{Binding IsTranslating, Converter={StaticResource InverseBooleanConverter}}"
                Margin="0,0,0,10"/>

        <!-- 结果区域 -->
        <Border Grid.Row="2"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Background="#FAFAFA"
                VerticalAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalAlignment="Stretch">
                <StackPanel>
                    <!-- 加载提示 -->
                    <TextBlock Text="{Binding LoadingText}"
                               Foreground="#999999"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Visibility="{Binding ShowLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- 错误消息 -->
                    <TextBox Text="{Binding ErrorMessage, Mode=OneWay}"
                             Foreground="#DC3545"
                             TextWrapping="Wrap"
                             FontSize="14"
                             TextAlignment="Justify"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             VerticalAlignment="Top"
                             Visibility="{Binding ShowError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- 翻译结果 -->
                    <ContentControl Content="{Binding TranslationResult}" Visibility="{Binding TranslationResult, Converter={StaticResource NullToVisibilityConverter}}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- 错误情况 -->
                                    <TextBox Text="{Binding TranslatedText, Mode=OneWay}"
                                             Foreground="#DC3545"
                                             TextWrapping="Wrap"
                                             FontSize="14"
                                             TextAlignment="Justify"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="0"
                                             VerticalAlignment="Top"
                                             Visibility="{Binding IsError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- 原文 -->
                                    <TextBlock Text="原文" FontWeight="Bold" FontSize="13" Foreground="#646464" Margin="0,15,0,8" Visibility="{Binding Text, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    <TextBox Text="{Binding Text, Mode=OneWay}"
                                             TextWrapping="Wrap"
                                             FontSize="14"
                                             Margin="0,0,0,8"
                                             Foreground="#323232"
                                             TextAlignment="Justify"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="0"
                                             VerticalAlignment="Top"
                                             VerticalScrollBarVisibility="Disabled"/>

                                    <!-- 英文单词翻译为中文 -->
                                    <!-- 译文 -->
                                    <TextBlock Text="译文" FontWeight="Bold" FontSize="13" Foreground="#646464" Margin="0,15,0,8" Visibility="{Binding IsEnToZhWord, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBox Text="{Binding TranslatedText, Mode=OneWay}"
                                             TextWrapping="Wrap"
                                             FontSize="15"
                                             FontWeight="Bold"
                                             Margin="0,0,0,15"
                                             Foreground="#007BFF"
                                             TextAlignment="Justify"
                                             IsReadOnly="True"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="0"
                                             VerticalAlignment="Top"
                                             VerticalScrollBarVisibility="Disabled"
                                             Visibility="{Binding IsEnToZhWord, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- 单词详情 -->
                                    <ItemsControl ItemsSource="{Binding WordDetails}" Margin="0,0,0,10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#DCDCDC" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10" Background="White">
                                                    <StackPanel>
                                                        <!-- 单词 + 音标 -->
                                                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#007BFF">
                                                            <Run Text="{Binding Word, Mode=OneWay}"/>
                                                            <Run Text="{Binding Phonetic, Mode=OneWay}" Foreground="#787878" FontSize="14"/>
                                                        </TextBlock>

                                                        <!-- 词性 + 释义 -->
                                                        <TextBox Text="{Binding DisplayDefinition, Mode=OneWay}"
                                                                 FontSize="14"
                                                                 Margin="0,5,0,0"
                                                                 TextWrapping="Wrap"
                                                                 TextAlignment="Justify"
                                                                 IsReadOnly="True"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 Padding="0"
                                                                 VerticalAlignment="Top"/>

                                                        <!-- 例句 -->
                                                        <TextBox Text="{Binding Example, Mode=OneWay}"
                                                                 FontSize="12"
                                                                 Foreground="#646464"
                                                                 FontStyle="Italic"
                                                                 TextWrapping="Wrap"
                                                                 Margin="0,8,0,0"
                                                                 TextAlignment="Justify"
                                                                 IsReadOnly="True"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 Padding="0"
                                                                 VerticalAlignment="Top"
                                                                 Visibility="{Binding Example, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        <TextBox Text="{Binding ExampleTranslation, Mode=OneWay}"
                                                                 FontSize="12"
                                                                 Foreground="#8C8C8C"
                                                                 TextWrapping="Wrap"
                                                                 Margin="0,2,0,0"
                                                                 TextAlignment="Justify"
                                                                 IsReadOnly="True"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 Padding="0"
                                                                 VerticalAlignment="Top"
                                                                 Visibility="{Binding ExampleTranslation, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 难词解释标题 -->
                                    <TextBlock Text="难词解释" FontWeight="Bold" FontSize="13" Foreground="#646464" Margin="0,15,0,8" Visibility="{Binding IsEnToZhSentence, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- 中文句子翻译为英文 -->
                                    <TextBlock Text="多种翻译" FontWeight="Bold" FontSize="13" Foreground="#646464" Margin="0,8,0,8" Visibility="{Binding IsZhToEn, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- 翻译选项 -->
                                    <ItemsControl ItemsSource="{Binding Options}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#DCDCDC" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12" Background="#FAFAFA">
                                                    <StackPanel>
                                                        <TextBox Text="{Binding Text, Mode=OneWay}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#007BFF" TextWrapping="Wrap" TextAlignment="Justify" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" VerticalAlignment="Top"/>
                                                        <TextBox Text="{Binding Scenario, Mode=OneWay}" FontSize="12" Foreground="#787878" FontStyle="Italic" Visibility="{Binding Scenario, Converter={StaticResource StringToVisibilityConverter}}" TextWrapping="Wrap" TextAlignment="Justify" IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0" VerticalAlignment="Top" Margin="0,0,0,5"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#888888"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>

</Window>
