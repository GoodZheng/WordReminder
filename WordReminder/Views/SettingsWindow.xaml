<Window x:Class="WordReminder.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WordReminder.Converters"
        xmlns:Controls="clr-namespace:WordReminder.Controls"
        Title="设置"
        Width="420"
        Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- 窗口设置页 -->
            <TabItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">

                        <TextBlock Text="窗口行为" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <CheckBox IsChecked="{Binding AlwaysOnTop}" Content="窗口置顶" Margin="0,5"/>
                        <CheckBox IsChecked="{Binding AutoStart}" Content="开机自启" Margin="0,5"/>

                        <Separator Margin="0,15"/>

                        <!-- 全局快捷键设置 -->
                        <TextBlock Text="全局快捷键" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="点击快捷键输入框后，按下要设置的组合键（如 Ctrl+Alt+W）" FontSize="11" Foreground="Gray" Margin="0,0,0,10"/>

                        <!-- 上一个 -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="上一个" VerticalAlignment="Center"/>
                            <Controls:HotKeyTextBox Grid.Column="1" Height="32" Margin="5,0"
                                                  HotKey="{Binding PreviousHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="清除" Command="{Binding ClearHotKeyCommand}" CommandParameter="Previous"
                                    Margin="5,0,0,0" Height="28" FontSize="12"/>
                        </Grid>

                        <!-- 下一个 -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="下一个" VerticalAlignment="Center"/>
                            <Controls:HotKeyTextBox Grid.Column="1" Height="32" Margin="5,0"
                                                  HotKey="{Binding NextHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="清除" Command="{Binding ClearHotKeyCommand}" CommandParameter="Next"
                                    Margin="5,0,0,0" Height="28" FontSize="12"/>
                        </Grid>

                        <!-- 播放/暂停 -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="播放/暂停" VerticalAlignment="Center"/>
                            <Controls:HotKeyTextBox Grid.Column="1" Height="32" Margin="5,0"
                                                  HotKey="{Binding PlayPauseHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="清除" Command="{Binding ClearHotKeyCommand}" CommandParameter="PlayPause"
                                    Margin="5,0,0,0" Height="28" FontSize="12"/>
                        </Grid>

                        <!-- 翻译 -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="翻译" VerticalAlignment="Center"/>
                            <Controls:HotKeyTextBox Grid.Column="1" Height="32" Margin="5,0"
                                                  HotKey="{Binding TranslationHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="清除" Command="{Binding ClearHotKeyCommand}" CommandParameter="Translation"
                                    Margin="5,0,0,0" Height="28" FontSize="12"/>
                        </Grid>

                        <!-- 窗口置顶 -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="窗口置顶" VerticalAlignment="Center"/>
                            <Controls:HotKeyTextBox Grid.Column="1" Height="32" Margin="5,0"
                                                  HotKey="{Binding ToggleTopmostHotKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="清除" Command="{Binding ClearHotKeyCommand}" CommandParameter="ToggleTopmost"
                                    Margin="5,0,0,0" Height="28" FontSize="12"/>
                        </Grid>

                        <TextBlock Text="按 ESC 键可清除快捷键" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>

                        <Separator Margin="0,15"/>

                        <TextBlock Text="显示效果" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- 切换间隔 -->
                        <StackPanel Margin="0,5">
                            <Grid>
                                <TextBlock Text="切换间隔" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding IntervalSeconds, StringFormat={}{0}秒}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider Minimum="1" Maximum="300"
                                    Value="{Binding IntervalSeconds}"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,5"/>
                        </StackPanel>

                        <!-- 透明度 -->
                        <StackPanel Margin="0,5">
                            <Grid>
                                <TextBlock Text="窗口透明度" VerticalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:F0}%">
                                            <Binding Path="Opacity"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                            <Slider Minimum="0.3" Maximum="1.0"
                                    Value="{Binding Opacity}"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,5"/>
                        </StackPanel>

                        <Separator Margin="0,15"/>

                        <TextBlock Text="AI 词典配置" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- API URL -->
                        <TextBlock Text="API URL" Margin="0,5"/>
                        <TextBox Text="{Binding ApiUrl}" Margin="0,5" Height="32" FontSize="12"/>
                        <TextBlock Text="AI 服务的 API 地址" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>

                        <!-- Model -->
                        <TextBlock Text="模型名称" Margin="0,5"/>
                        <TextBox Text="{Binding Model}" Margin="0,5" Height="32" FontSize="12"/>
                        <TextBlock Text="AI 模型的 ID 或名称" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>

                        <!-- API Key -->
                        <TextBlock Text="API Key" Margin="0,5"/>
                        <PasswordBox x:Name="ApiKeyPasswordBox" Margin="0,5" PasswordChar="•" Height="32" FontSize="12"/>
                        <TextBlock Text="用于 AI 词典服务的 API 密钥" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 内容设置页 -->
            <TabItem Header="内容">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">

                        <TextBlock Text="显示内容" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <CheckBox IsChecked="{Binding ShowPhonetic}" Content="显示音标" Margin="0,8"/>
                        <TextBlock Text="在单词右侧显示音标" FontSize="12" Foreground="Gray" Margin="20,0,0,5"/>

                        <CheckBox IsChecked="{Binding ShowDefinition}" Content="显示释义" Margin="0,8"/>
                        <TextBlock Text="显示词性和中文释义" FontSize="12" Foreground="Gray" Margin="20,0,0,5"/>

                        <CheckBox IsChecked="{Binding ShowExample}" Content="显示例句" Margin="0,8"/>
                        <TextBlock Text="显示英文例句" FontSize="12" Foreground="Gray" Margin="20,0,0,5"/>

                        <Separator Margin="0,20"/>

                        <!-- 样式设置 -->
                        <TextBlock Text="字体样式" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- 单词样式 -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="单词" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="12" Maximum="72"
                                        Value="{Binding WordFontSize}"
                                        TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding WordFontSize}" Width="25" TextAlignment="Right"/>
                            </Grid>

                            <Button Grid.Column="2" Width="40" Height="22" Margin="5,0,0,0"
                                    Command="{Binding SelectColorCommand}" CommandParameter="Word"
                                    Background="{Binding WordColorBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- 音标样式 -->
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="音标" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="8" Maximum="36"
                                        Value="{Binding PhoneticFontSize}"
                                        TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding PhoneticFontSize}" Width="25" TextAlignment="Right"/>
                            </Grid>

                            <Button Grid.Column="2" Width="40" Height="22" Margin="5,0,0,0"
                                    Command="{Binding SelectColorCommand}" CommandParameter="Phonetic"
                                    Background="{Binding PhoneticColorBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- 释义样式 -->
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="释义" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="10" Maximum="36"
                                        Value="{Binding DefinitionFontSize}"
                                        TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding DefinitionFontSize}" Width="25" TextAlignment="Right"/>
                            </Grid>

                            <Button Grid.Column="2" Width="40" Height="22" Margin="5,0,0,0"
                                    Command="{Binding SelectColorCommand}" CommandParameter="Definition"
                                    Background="{Binding DefinitionColorBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- 例句样式 -->
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="例句" FontWeight="Bold" VerticalAlignment="Center"/>

                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="8" Maximum="24"
                                        Value="{Binding ExampleFontSize}"
                                        TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding ExampleFontSize}" Width="25" TextAlignment="Right"/>
                            </Grid>

                            <Button Grid.Column="2" Width="40" Height="22" Margin="5,0,0,0"
                                    Command="{Binding SelectColorCommand}" CommandParameter="Example"
                                    Background="{Binding ExampleColorBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <TextBlock Text="点击右侧颜色块打开颜色选择器" FontSize="11" Foreground="Gray" Margin="0,5,0,0" HorizontalAlignment="Center"/>

                        <Separator Margin="0,20"/>

                        <!-- 单词管理 -->
                        <TextBlock Text="单词数据" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding WordCountText}" Margin="0,5" FontSize="14"/>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,5">
                            重新加载会从必应词典获取最新的单词数据，包括音标、释义和例句。
                        </TextBlock>

                        <Button Content="{Binding ReloadWordsButtonText}"
                                Command="{Binding ReloadWordsCommand}"
                                IsEnabled="{Binding IsReloadWordsEnabled}"
                                Margin="0,15" Height="35"/>

                        <Separator Margin="0,20"/>

                        <TextBlock Text="关于" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray">
                            单词来源：内置20个四级核心词汇，支持从必应词典获取例句。
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 关于页 -->
            <TabItem Header="关于">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- 应用图标和名称 -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock Text="📚 WordReminder" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <TextBlock Text="桌面单词记忆软件" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- 版本信息 -->
                        <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel>
                                <Grid Margin="0,5">
                                    <TextBlock Text="当前版本" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentVersionText}" HorizontalAlignment="Right" Foreground="Gray"/>
                                </Grid>
                                <Grid Margin="0,5">
                                    <TextBlock Text="最新版本" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding LatestVersionText}"
                                               HorizontalAlignment="Right"
                                               Foreground="{Binding LatestVersionForegroundColor}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 更新操作 -->
                        <Button Content="{Binding CheckUpdateButtonText}"
                                Command="{Binding CheckUpdateCommand}"
                                IsEnabled="{Binding IsCheckUpdateEnabled}"
                                Margin="0,0,0,10" Height="40" FontSize="14"/>
                        <Button Content="下载更新"
                                Command="{Binding DownloadUpdateCommand}"
                                IsEnabled="{Binding IsDownloadUpdateEnabled}"
                                Margin="0,0,0,10" Height="40" FontSize="14"/>

                        <!-- 下载进度 -->
                        <Border Background="#F5F5F5" Padding="15" CornerRadius="5" Margin="0,0,0,15"
                                Visibility="{Binding ShowDownloadProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding DownloadStatusText}" Margin="0,0,0,10"/>
                                <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding DownloadProgress}"/>
                            </StackPanel>
                        </Border>

                        <!-- 自动更新开关 -->
                        <CheckBox IsChecked="{Binding AutoUpdate}" Content="自动检查更新（启动时）" Margin="0,10"/>

                        <Separator Margin="0,20"/>

                        <!-- 开发者信息 -->
                        <TextBlock Text="开发者信息" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            <Run Text="开发者：" FontWeight="Bold"/>
                            <Run Text="WordReminder Team"/>
                        </TextBlock>

                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            <Run Text="GitHub：" FontWeight="Bold"/>
                            <Run Text="github.com/GoodZheng/WordReminder" Foreground="Blue" Cursor="Hand">
                                <Run.InputBindings>
                                    <MouseBinding Command="{Binding OpenGitHubLinkCommand}" MouseAction="LeftClick"/>
                                </Run.InputBindings>
                            </Run>
                        </TextBlock>

                        <Separator Margin="0,20"/>

                        <!-- 版权信息 -->
                        <TextBlock Text="版权" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,5">
                            © 2025 WordReminder. All rights reserved.
                        </TextBlock>

                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,5">
                            本软件免费开源，仅供学习使用。
                        </TextBlock>

                        <Separator Margin="0,20"/>

                        <!-- 功能说明 -->
                        <TextBlock Text="功能说明" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 透明窗口展示单词
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 内置20个四级核心词汇
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 支持从必应词典获取单词详情
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 可自定义字体、颜色、透明度
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,5">
                            • 支持开机自启
                        </TextBlock>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- 保存按钮 -->
        <Button Grid.Row="1" Content="保存设置"
                Command="{Binding SaveCommand}"
                Margin="0,15,0,0" Height="40" FontSize="14"/>

    </Grid>

</Window>
