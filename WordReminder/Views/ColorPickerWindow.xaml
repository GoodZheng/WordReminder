<Window x:Class="WordReminder.Views.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择颜色"
        Width="280"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Text="选择颜色" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- 颜色网格 -->
        <UniformGrid Grid.Row="1" Columns="6" Margin="0,5">
            <!-- 白色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#FFFFFF" Command="{Binding SelectColorCommand}" CommandParameter="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="1"/>
            <Button Width="30" Height="30" Margin="2" Background="#DDDDDD" Command="{Binding SelectColorCommand}" CommandParameter="#DDDDDD"/>
            <Button Width="30" Height="30" Margin="2" Background="#CCCCCC" Command="{Binding SelectColorCommand}" CommandParameter="#CCCCCC"/>
            <Button Width="30" Height="30" Margin="2" Background="#AAAAAA" Command="{Binding SelectColorCommand}" CommandParameter="#AAAAAA"/>
            <Button Width="30" Height="30" Margin="2" Background="#888888" Command="{Binding SelectColorCommand}" CommandParameter="#888888"/>
            <Button Width="30" Height="30" Margin="2" Background="#666666" Command="{Binding SelectColorCommand}" CommandParameter="#666666"/>

            <!-- 红色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#FF6B6B" Command="{Binding SelectColorCommand}" CommandParameter="#FF6B6B"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF4444" Command="{Binding SelectColorCommand}" CommandParameter="#FF4444"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF0000" Command="{Binding SelectColorCommand}" CommandParameter="#FF0000"/>
            <Button Width="30" Height="30" Margin="2" Background="#FFB6C1" Command="{Binding SelectColorCommand}" CommandParameter="#FFB6C1"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF69B4" Command="{Binding SelectColorCommand}" CommandParameter="#FF69B4"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF1493" Command="{Binding SelectColorCommand}" CommandParameter="#FF1493"/>

            <!-- 橙黄色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#FFA500" Command="{Binding SelectColorCommand}" CommandParameter="#FFA500"/>
            <Button Width="30" Height="30" Margin="2" Background="#FF8C00" Command="{Binding SelectColorCommand}" CommandParameter="#FF8C00"/>
            <Button Width="30" Height="30" Margin="2" Background="#FFD700" Command="{Binding SelectColorCommand}" CommandParameter="#FFD700"/>
            <Button Width="30" Height="30" Margin="2" Background="#FFFF00" Command="{Binding SelectColorCommand}" CommandParameter="#FFFF00"/>
            <Button Width="30" Height="30" Margin="2" Background="#F0E68C" Command="{Binding SelectColorCommand}" CommandParameter="#F0E68C"/>
            <Button Width="30" Height="30" Margin="2" Background="#B8860B" Command="{Binding SelectColorCommand}" CommandParameter="#B8860B"/>

            <!-- 绿色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#90EE90" Command="{Binding SelectColorCommand}" CommandParameter="#90EE90"/>
            <Button Width="30" Height="30" Margin="2" Background="#00FF00" Command="{Binding SelectColorCommand}" CommandParameter="#00FF00"/>
            <Button Width="30" Height="30" Margin="2" Background="#32CD32" Command="{Binding SelectColorCommand}" CommandParameter="#32CD32"/>
            <Button Width="30" Height="30" Margin="2" Background="#228B22" Command="{Binding SelectColorCommand}" CommandParameter="#228B22"/>
            <Button Width="30" Height="30" Margin="2" Background="#008000" Command="{Binding SelectColorCommand}" CommandParameter="#008000"/>
            <Button Width="30" Height="30" Margin="2" Background="#006400" Command="{Binding SelectColorCommand}" CommandParameter="#006400"/>

            <!-- 青色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#00FFFF" Command="{Binding SelectColorCommand}" CommandParameter="#00FFFF"/>
            <Button Width="30" Height="30" Margin="2" Background="#00CED1" Command="{Binding SelectColorCommand}" CommandParameter="#00CED1"/>
            <Button Width="30" Height="30" Margin="2" Background="#20B2AA" Command="{Binding SelectColorCommand}" CommandParameter="#20B2AA"/>
            <Button Width="30" Height="30" Margin="2" Background="#008B8B" Command="{Binding SelectColorCommand}" CommandParameter="#008B8B"/>
            <Button Width="30" Height="30" Margin="2" Background="#5F9EA0" Command="{Binding SelectColorCommand}" CommandParameter="#5F9EA0"/>
            <Button Width="30" Height="30" Margin="2" Background="#4682B4" Command="{Binding SelectColorCommand}" CommandParameter="#4682B4"/>

            <!-- 蓝色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#87CEEB" Command="{Binding SelectColorCommand}" CommandParameter="#87CEEB"/>
            <Button Width="30" Height="30" Margin="2" Background="#1E90FF" Command="{Binding SelectColorCommand}" CommandParameter="#1E90FF"/>
            <Button Width="30" Height="30" Margin="2" Background="#0000FF" Command="{Binding SelectColorCommand}" CommandParameter="#0000FF"/>
            <Button Width="30" Height="30" Margin="2" Background="#4169E1" Command="{Binding SelectColorCommand}" CommandParameter="#4169E1"/>
            <Button Width="30" Height="30" Margin="2" Background="#00008B" Command="{Binding SelectColorCommand}" CommandParameter="#00008B"/>
            <Button Width="30" Height="30" Margin="2" Background="#191970" Command="{Binding SelectColorCommand}" CommandParameter="#191970"/>

            <!-- 紫色系 -->
            <Button Width="30" Height="30" Margin="2" Background="#DDA0DD" Command="{Binding SelectColorCommand}" CommandParameter="#DDA0DD"/>
            <Button Width="30" Height="30" Margin="2" Background="#DA70D6" Command="{Binding SelectColorCommand}" CommandParameter="#DA70D6"/>
            <Button Width="30" Height="30" Margin="2" Background="#9370DB" Command="{Binding SelectColorCommand}" CommandParameter="#9370DB"/>
            <Button Width="30" Height="30" Margin="2" Background="#8A2BE2" Command="{Binding SelectColorCommand}" CommandParameter="#8A2BE2"/>
            <Button Width="30" Height="30" Margin="2" Background="#9400D3" Command="{Binding SelectColorCommand}" CommandParameter="#9400D3"/>
            <Button Width="30" Height="30" Margin="2" Background="#4B0082" Command="{Binding SelectColorCommand}" CommandParameter="#4B0082"/>
        </UniformGrid>

        <!-- 自定义颜色输入 -->
        <Grid Grid.Row="2" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="自定义:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding CustomColorText, UpdateSourceTrigger=PropertyChanged}"/>
            <Border Grid.Column="2" Width="30" Height="22" Margin="8,0,0,0" BorderBrush="#CCCCCC" BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush Color="{Binding PreviewColor}"/>
                </Border.Background>
            </Border>
        </Grid>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="75" Height="28" Margin="5,0" Command="{Binding OkCommand}" IsDefault="True"/>
            <Button Content="取消" Width="75" Height="28" Margin="5,0" Command="{Binding CancelCommand}" IsCancel="True"/>
        </StackPanel>

    </Grid>

</Window>
