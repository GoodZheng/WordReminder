<Window x:Class="WordReminder.Views.AllWordsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="所有单词"
        Width="800"
        Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 批量操作工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="全选" Width="60" Height="25" Margin="0,0,10,0" Command="{Binding SelectAllCommand}"/>
            <Button Content="反选" Width="60" Height="25" Margin="0,0,10,0" Command="{Binding InvertSelectionCommand}"/>
            <Button Content="取消选择" Width="70" Height="25" Margin="0,0,10,0" Command="{Binding CancelSelectionCommand}"/>
            <Separator Width="1" Margin="10,0"/>
            <Button Content="批量删除" Width="70" Height="25" Margin="10,0,10,0" Command="{Binding BatchDeleteCommand}" CommandParameter="{Binding ElementName=WordsDataGrid, Path=SelectedItems}"/>
            <Button Content="{Binding BatchUpdateButtonText}"
                    Width="70"
                    Height="25"
                    Margin="0,0,10,0"
                    Command="{Binding BatchUpdateCommand}"
                    CommandParameter="{Binding ElementName=WordsDataGrid, Path=SelectedItems}"
                    IsEnabled="{Binding IsBatchUpdateEnabled}"/>
            <TextBlock Text="{Binding SelectedCountText}" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>

        <DataGrid x:Name="WordsDataGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Words}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  AllowDrop="True"
                  SelectionChanged="WordsDataGrid_SelectionChanged"
                  PreviewMouseLeftButtonDown="WordsDataGrid_PreviewMouseLeftButtonDown"
                  MouseMove="WordsDataGrid_MouseMove"
                  DragEnter="WordsDataGrid_DragEnter"
                  Drop="WordsDataGrid_Drop">
            <DataGrid.Columns>
                <DataGridTextColumn Header="单词" Binding="{Binding Text}" Width="100"/>
                <DataGridTextColumn Header="音标" Binding="{Binding Phonetic}" Width="100"/>
                <DataGridTextColumn Header="词性" Binding="{Binding PartOfSpeech}" Width="60"/>
                <DataGridTextColumn Header="释义" Binding="{Binding Definition}" Width="*"/>
                <DataGridTextColumn Header="例句" Binding="{Binding Example}" Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="操作" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="更新" Width="50" Height="25" Margin="0,0,5,0" Command="{Binding DataContext.UpdateWordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                <Button Content="删除" Width="50" Height="25" Command="{Binding DataContext.DeleteWordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <TextBlock Text="提示：拖动行可调整顺序 • 按住 Ctrl/Shift 多选" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray"/>
            <Button Content="关闭" Width="70" Height="25" Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</Window>
