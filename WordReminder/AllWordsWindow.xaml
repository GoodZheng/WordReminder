<Window x:Class="WordReminder.AllWordsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="所有单词"
        Width="800"
        Height="500"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 批量操作工具栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="SelectAllButton" Content="全选" Width="60" Height="25" Margin="0,0,10,0" Click="SelectAll_Click"/>
            <Button x:Name="InvertSelectionButton" Content="反选" Width="60" Height="25" Margin="0,0,10,0" Click="InvertSelection_Click"/>
            <Button x:Name="CancelSelectionButton" Content="取消选择" Width="70" Height="25" Margin="0,0,10,0" Click="CancelSelection_Click"/>
            <Separator Width="1" Margin="10,0"/>
            <Button x:Name="BatchDeleteButton" Content="批量删除" Width="70" Height="25" Margin="10,0,10,0" Click="BatchDelete_Click"/>
            <Button x:Name="BatchUpdateButton" Content="批量更新" Width="70" Height="25" Margin="0,0,10,0" Click="BatchUpdate_Click"/>
            <TextBlock x:Name="SelectedCountText" Text="已选择：0 项" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>

        <DataGrid x:Name="WordsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  AllowDrop="True"
                  MouseMove="WordsDataGrid_MouseMove"
                  Drop="WordsDataGrid_Drop"
                  DragEnter="WordsDataGrid_DragEnter"
                  PreviewMouseLeftButtonDown="WordsDataGrid_PreviewMouseLeftButtonDown"
                  SelectionChanged="WordsDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="单词" Binding="{Binding Text}" Width="100"/>
                <DataGridTextColumn Header="音标" Binding="{Binding Phonetic}" Width="100"/>
                <DataGridTextColumn Header="词性" Binding="{Binding PartOfSpeech}" Width="60"/>
                <DataGridTextColumn Header="释义" Binding="{Binding Definition}" Width="*"/>
                <DataGridTextColumn Header="例句" Binding="{Binding Example}" Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="操作" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="更新" Width="50" Height="25" Margin="0,0,5,0" Click="Update_Click" Tag="{Binding}"/>
                                <Button Content="删除" Width="50" Height="25" Click="Delete_Click" Tag="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <TextBlock Text="提示：拖动行可调整顺序 • 按住 Ctrl/Shift 多选" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray"/>
            <Button Content="关闭" Width="70" Height="25" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
